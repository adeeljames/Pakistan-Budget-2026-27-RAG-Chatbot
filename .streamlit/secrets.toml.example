# Streamlit Secrets Template
# Copy this to .streamlit/secrets.toml and fill in your keys
# For Streamlit Cloud: Add these in the app settings → Secrets

PINECONE_API_KEY = "your_pinecone_api_key_here"
PINECONE_INDEX_NAME = "budget-rag"
PINECONE_HOST_URL = "your_pinecone_host_url_here"
CEREBRAS_API_KEY = "your_cerebras_api_key_here"
CEREBRAS_MODEL = "zai-glm-4.7"
EMBEDDING_MODEL = "multilingual-e5-large"
